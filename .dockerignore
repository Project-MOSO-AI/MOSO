# .dockerignore — exclude everything not needed in the image

# Version control
.git/
.github/
.gitignore

# Development
.venv/
.env
.env.*
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Models (mounted as external volume)
models/
*.gguf
*.bin
*.pth

# User data (mounted as external volume)
.moso/
*.db
*.sqlite

# Tests
tests/
test_*.py
conftest.py
pytest.ini

# Documentation
docs/
README.md
LICENSE
SECURITY.md
llms.txt

# Docker files
Dockerfile
.dockerignore
docker-compose*.yml

# Temporary
*.log
*.tmp
tmp/
temp/
logs/
