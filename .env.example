# MOSO AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
MOSO_ENV=development
MOSO_LOG_LEVEL=debug
MOSO_DATA_DIR=./data

# Model Configuration
MOSO_LLM_MODEL=phi-3-mini-4k-instruct-q4.gguf
MOSO_LLM_MODEL_PATH=./models/llm/phi3/
MOSO_WHISPER_MODEL=base
MOSO_TTS_MODEL=piper
MOSO_TTS_VOICE=en_US-lessac-medium

# Voice Pipeline
VOICE_ENABLED=true
VOICE_WAKE_WORD=hey moso, hello moso, ok moso
VOICE_SPEAKER_VERIFY=true
VOICE_SPEAKER_THRESHOLD=0.95
VOICE_REVERIFY_INTERVAL_MS=60000
VOICE_SESSION_TIMEOUT_MS=300000
VOICE_SAMPLE_RATE=16000
VOICE_SILENCE_DURATION_MS=500

# Speaker Enrollment
VOICE_ENROLL_SAMPLES=3
VOICE_ENROLL_DURATION_SEC=3.0

# Identity Engine
IDENTITY_ENABLED=true
IDENTITY_CONFIDENCE_OWNER=95
IDENTITY_CONFIDENCE_LIKELY=80
IDENTITY_CONFIDENCE_GUEST=60
IDENTITY_REVERIFY_INTERVAL_MS=60000
IDENTITY_SESSION_TIMEOUT_MS=300000
IDENTITY_WEIGHT_VOICE=0.35
IDENTITY_WEIGHT_LIVENESS=0.20
IDENTITY_WEIGHT_BEHAVIOR=0.20
IDENTITY_WEIGHT_DEVICE=0.15
IDENTITY_WEIGHT_HISTORICAL=0.10

# Anti-Spoofing
ANTISPOOF_LIVENESS_THRESHOLD=0.85
ANTISPOOF_CHECK_SPECTRAL=true
ANTISPOOF_CHECK_ENERGY=true

# Behavioral Biometrics
BEHAVIOR_BASELINE_SAMPLES=10
BEHAVIOR_MAX_HISTORY=100

# Device Presence
DEVICE_BLUETOOTH_SCAN=true
DEVICE_WIFI_SCAN=true
DEVICE_TRUSTED_BLUETOOTH=
DEVICE_TRUSTED_SSID=

# Historical Context
HISTORY_ENABLED=true
HISTORY_STORE_PATH=~/.moso/history

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_API_PREFIX=/api/v1

# Security
ENCRYPTION_ALGORITHM=AES-256-GCM
